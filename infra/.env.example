# =============================================================================
#  Exemple de configuration — copiez ce fichier en .env et adaptez les valeurs
#
#  cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
#  PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=airflow
POSTGRES_PASSWORD=changeme
AIRFLOW_POSTGRES_PORT=5433

# ---------------------------------------------------------------------------
#  Airflow
# ---------------------------------------------------------------------------
# Générer une clé Fernet : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_GENERATE_A_REAL_KEY
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=changeme

# ---------------------------------------------------------------------------
#  API externes
# ---------------------------------------------------------------------------
AVIATIONSTACK_API_KEY=YOUR_API_KEY_HERE
